{
  "extends": [
    "development"
  ],
  "browserslist": [
    "defaults",
    "not ie 11",
    "not safari <= 26.2"
  ],
  "hints": {
    "axe/forms": "off",
    "axe/language": [
      "default",
      {
        "html-lang-valid": "off"
      }
    ],
    "axe/structure": [
      "default",
      {
        "list": "off"
      }
    ]
  }
}